{
  "version": 2,
  "buildCommand": "cd food-ai && npm install && npm run build",
  "outputDirectory": "food-ai/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://yeschef-production.up.railway.app/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://yeschef-production.up.railway.app/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
