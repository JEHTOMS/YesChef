{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd food-ai && npm ci --omit=dev"
  },
  "deploy": {
    "startCommand": "cd food-ai && node server-clean.mjs",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 180
  }
}
