{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd food-ai && npm install --omit=dev && pip install youtube-transcript-api"
  },
  "deploy": {
    "startCommand": "cd food-ai && node server-clean.mjs",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120
  }
}
